# Copy this file to .env if you want to override local defaults.
# 如果你想覆盖本地默认配置，可以复制本文件为 .env。

# Local embedding model used by sentence-transformers.
# sentence-transformers 使用的本地 embedding 模型。
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Default number of chunks to retrieve.
# 默认检索 chunk 数量。
TOP_K=5

# Local Ollama HTTP API endpoint.
# 本地 Ollama HTTP API 地址。
OLLAMA_BASE_URL=http://localhost:11434

# Local Ollama model used by scripts/chat_cli.py.
# scripts/chat_cli.py 使用的本地 Ollama 模型。
OLLAMA_MODEL=llama3.1:8b

# OpenAI-compatible hosted LLM provider.
# OpenAI-compatible 线上 LLM provider。
LLM_PROVIDER=openai_compatible

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano


# Optional: Hugging Face token for higher rate limits or private models.
# 可选：Hugging Face token，用于更高下载限额或私有模型。
# HF_TOKEN=

# Local or deployed Chroma persistent directory.
# 本地或线上 Chroma 持久化目录。
CHROMA_PATH=data/vectorstores/chroma

# Chroma collection name.
# Chroma collection 名称。
CHROMA_COLLECTION=srd_5_2_1_en

# Embedding provider: openai or local.
# embedding provider，可选 openai 或 local。
EMBEDDING_PROVIDER=openai

# OpenAI embedding model used for indexing and query embeddings.
# 用于索引和查询的 OpenAI embedding 模型。
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local embedding model, only used when EMBEDDING_PROVIDER=local.
# 仅在 EMBEDDING_PROVIDER=local 时使用。
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B